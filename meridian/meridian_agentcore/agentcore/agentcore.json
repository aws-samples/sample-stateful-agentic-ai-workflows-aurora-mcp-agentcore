{
  "$schema": "https://schema.agentcore.aws.dev/v1/agentcore.json",
  "name": "meridian_agentcore",
  "version": 1,
  "managedBy": "CDK",
  "tags": {
    "agentcore:created-by": "agentcore-cli",
    "agentcore:project-name": "meridian_agentcore"
  },
  "runtimes": [
    {
      "name": "MeridianConcierge",
      "build": "CodeZip",
      "entrypoint": "main.py",
      "codeLocation": "app/MeridianConcierge/",
      "runtimeVersion": "PYTHON_3_14",
      "networkMode": "PUBLIC",
      "protocol": "HTTP"
    }
  ],
  "memories": [
    {
      "name": "meridian_session",
      "eventExpiryDuration": 30,
      "strategies": [
        {
          "type": "SEMANTIC",
          "namespaceTemplates": [
            "/users/{actorId}/facts"
          ]
        }
      ]
    }
  ],
  "credentials": [],
  "evaluators": [],
  "onlineEvalConfigs": [],
  "agentCoreGateways": [
    {
      "name": "meridian-aurora",
      "description": "Gateway for meridian-aurora",
      "targets": [
        {
          "name": "SemanticTripSearchLambda",
          "targetType": "lambdaFunctionArn",
          "lambdaFunctionArn": {
            "lambdaArn": "arn:aws:lambda:us-east-1:619763002613:function:meridian-semantic-trip-search",
            "toolSchemaFile": "./agentcore/gateway_targets/semantic_trip_search/tool-schema.json"
          }
        }
      ],
      "authorizerType": "AWS_IAM",
      "enableSemanticSearch": true,
      "exceptionLevel": "NONE"
    }
  ],
  "policyEngines": [],
  "configBundles": [],
  "abTests": [],
  "httpGateways": [],
  "datasets": []
}