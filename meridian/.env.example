# Copy to .env and fill in your values. Never commit .env.
# AWS auth: use `aws configure`, an IAM role, or env vars below (optional).
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1

# Bedrock — LLM identifier used by every Strands agent (phases 1–5).
# Default is the Global cross-Region inference profile for Anthropic Claude
# Sonnet 5. If you see "ValidationException: The provided model identifier
# is invalid" at runtime, switch to a profile your account has access to.
# Run `aws bedrock list-inference-profiles --region us-east-1` to see what's
# available, e.g.:
#   global.anthropic.claude-sonnet-5                    # recommended live demo default
#   global.anthropic.claude-sonnet-4-5-20250929-v1:0   # cheaper, broadly available
#   global.anthropic.claude-haiku-4-5-20251001-v1:0    # cheapest
#   us.anthropic.claude-opus-4-8                         # US-only profile
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-5
BEDROCK_REGION=us-east-1

# Embeddings (Cohere Embed v4 — 1024d for Aurora pgvector)
EMBEDDING_MODEL=cohere.embed-v4:0
EMBEDDING_DIMENSION=1024

# Aurora PostgreSQL (RDS Data API)
AURORA_HOST=your_cluster_endpoint
AURORA_PORT=5432
AURORA_DATABASE=meridian
AURORA_USERNAME=meridian_admin
AURORA_CLUSTER_ARN=arn:aws:rds:region:account-id:cluster:your-cluster
AURORA_SECRET_ARN=arn:aws:secretsmanager:region:account-id:secret:your-secret
AURORA_CLUSTER_IDENTIFIER=your_cluster_identifier
AURORA_CLUSTER_ENDPOINT=your_cluster_endpoint

# Connection pool (optional, direct psycopg use)
AURORA_MIN_POOL_SIZE=2
AURORA_MAX_POOL_SIZE=20
AURORA_POOL_TIMEOUT=30

# Durable LangGraph checkpoints (Phase 5)
# Use a dedicated least-privilege checkpoint role/secret in production.
# LANGGRAPH_CHECKPOINT_DSN=postgresql://checkpoint_user:password@host:5432/meridian?sslmode=require
# LANGGRAPH_CHECKPOINT_SECRET_ARN=
# LANGGRAPH_CHECKPOINT_HOST=
# LANGGRAPH_CHECKPOINT_DATABASE=meridian
# LANGGRAPH_CHECKPOINT_POOL_MIN_SIZE=1
# LANGGRAPH_CHECKPOINT_POOL_MAX_SIZE=10
# LANGGRAPH_CHECKPOINT_POOL_TIMEOUT=10
# LANGGRAPH_CHECKPOINT_CONNECT_TIMEOUT=5
# LANGGRAPH_CHECKPOINT_REQUIRED=false       # true: fail closed without PostgresSaver
# LANGGRAPH_CHECKPOINT_INIT_ON_STARTUP=false
# LANGGRAPH_AUTO_CHECKPOINT_DSN=true         # reuse Aurora env/secret for local demo only
# LANGGRAPH_DEMO_INTERRUPT_AFTER=search      # stage proof: pause, restart, resume

# Logging
LOG_LEVEL=INFO
# Emit agent / tool / skill detail on every chat turn (set false to quiet logs)
LOG_AGENT_VERBOSE=true
# LOG_JSON=false
SQL_ECHO=false

# Orchestration — Phase 3/4 use live Strands + Bedrock tool routing (no procedural fallback).
# STRANDS_ORCHESTRATION=full

# Bedrock AgentCore — Phase 4 (required: Runtime + Gateway + Memory)
#
#   npm install -g @aws/agentcore
#   cd meridian/meridian_agentcore/agentcore && agentcore deploy -y
#   cd ../.. && python scripts/sync_agentcore_env.py --write
#
# Resource IDs auto-load from meridian_agentcore/agentcore/.cli/deployed-state.json
# AGENTCORE_PROJECT_DIR=/absolute/path/to/meridian/meridian_agentcore/agentcore   # optional override
# AGENTCORE_SKIP_CLI_SYNC=1                  # skip `agentcore status --json` subprocess
# AGENTCORE_REGION=us-east-1
#
# Manual overrides (optional — env wins over CLI state):
# AGENTCORE_RUNTIME_ARN=
# AGENTCORE_GATEWAY_URL=
# AGENTCORE_MEMORY_ID=
# AGENTCORE_WORKLOAD_IDENTITY=
# AGENTCORE_RESOURCE_PROVIDER=
