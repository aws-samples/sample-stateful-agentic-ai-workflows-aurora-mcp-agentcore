# Copy to .env and fill in your values. Never commit .env.
# AWS auth: use `aws configure`, an IAM role, or env vars below (optional).
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1

# Bedrock
BEDROCK_MODEL_ID=global.anthropic.claude-opus-4-7-v1
BEDROCK_REGION=us-east-1

# Embeddings (Cohere Embed v4 — 1024d for Aurora pgvector)
EMBEDDING_MODEL=cohere.embed-v4:0
EMBEDDING_DIMENSION=1024

# Aurora PostgreSQL (RDS Data API)
AURORA_HOST=your_cluster_endpoint
AURORA_PORT=5432
AURORA_DATABASE=meridian
AURORA_USERNAME=meridian_admin
AURORA_CLUSTER_ARN=arn:aws:rds:region:account-id:cluster:your-cluster
AURORA_SECRET_ARN=arn:aws:secretsmanager:region:account-id:secret:your-secret
AURORA_CLUSTER_IDENTIFIER=your_cluster_identifier
AURORA_CLUSTER_ENDPOINT=your_cluster_endpoint

# Connection pool (optional, direct psycopg use)
AURORA_MIN_POOL_SIZE=2
AURORA_MAX_POOL_SIZE=20
AURORA_POOL_TIMEOUT=30

# Logging
LOG_LEVEL=INFO
SQL_ECHO=false

# Orchestration mode
# - full     (default): Phase 3 supervisor and Phase 4 concierge invoke Bedrock
#                       via Strands so the LLM picks tools.
# - fallback           : skips the LLM and runs the procedural search/recall
#                        path (use for offline demos or to avoid Bedrock cost).
STRANDS_ORCHESTRATION=full

# Bedrock AgentCore Memory (Phase 4 session store)
# Provision with: aws bedrock-agentcore-control create-memory --name meridian-session
# When unset the concierge logs "unconfigured" and falls back to Aurora-only.
# AGENTCORE_MEMORY_ID=
# AGENTCORE_REGION=us-east-1

# Bedrock AgentCore Identity (per-turn workload identity)
# AGENTCORE_WORKLOAD_IDENTITY=arn:aws:bedrock-agentcore:us-east-1:ACCOUNT:workload-identity/meridian
# AGENTCORE_RESOURCE_PROVIDER=meridian-aurora-rds-data
# AGENTCORE_WORKLOAD_TOKEN=  # JWT minted by AgentCore Runtime; usually set by the runtime, not by hand
